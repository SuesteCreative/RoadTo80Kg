# Neon Postgres connection string (pooled URL works fine with @neondatabase/serverless)
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Local dev: http://localhost:3000 — Prod: https://roadto80kg.vercel.app
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Protects /api/cron/* endpoints. Vercel Cron sends this as Bearer token.
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# Optional — only if Continente starts blocking and we switch to headless browser
# SCRAPE_MODE="cheerio" | "headless"
SCRAPE_MODE="cheerio"

# Claude API (opcional — habilita "Pedir ajuste" em receitas/treinos e coach no dashboard)
# Obtém em https://console.anthropic.com → Settings → API Keys
# Modelo usado: claude-haiku-4-5
# O código aceita ANTHROPIC_API_KEY ou ANTHROPIC_SECRET (qualquer um serve)
ANTHROPIC_API_KEY=""
